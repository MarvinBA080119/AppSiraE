<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_header_gradient"
    tools:context=".home.account.accountFragment">

    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:contentDescription="@string/cd_logo"
        android:src="@drawable/logo_blanco_transparente"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:text="@string/cuenta_title"
        android:textAppearance="?attr/textAppearanceHeadlineMedium"
        android:textColor="@color/brand_on_primary"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ivLogo" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/cardContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_card_top_rounded"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="24dp"
            android:paddingTop="32dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:background="@drawable/bg_circle_primary"
                android:contentDescription="@string/cd_person_icon"
                android:padding="20dp"
                android:src="@drawable/ic_people"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/brand_on_primary" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvNombreCompleto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="@color/brand_primary_dark"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/ivAvatar"
                tools:text="Samuel Betancourt" />

            <!-- ===== TARJETA CON INFORMACIÓN DEL USUARIO ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/infoContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/neutral_white"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvNombreCompleto"
                app:strokeColor="@color/brand_primary_light"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <!-- Usuario -->
                    <ImageView
                        android:id="@+id/ivUsername"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="@string/cuenta_usuario_label"
                        android:src="@drawable/ic_at"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/brand_primary" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvUsernameLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/cuenta_usuario_label"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="@color/brand_primary_light"
                        app:layout_constraintStart_toEndOf="@+id/ivUsername"
                        app:layout_constraintTop_toTopOf="@+id/ivUsername" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvUsernameValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/brand_primary_dark"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/ivUsername"
                        app:layout_constraintTop_toBottomOf="@+id/tvUsernameLabel"
                        tools:text="Mbetan" />

                    <View
                        android:id="@+id/divider1"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="@color/brand_primary_light"
                        android:alpha="0.25"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tvUsernameValue" />

                    <!-- Teléfono -->
                    <ImageView
                        android:id="@+id/ivPhone"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_marginTop="16dp"
                        android:contentDescription="@string/cuenta_telefono_label"
                        android:src="@drawable/ic_phone"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/divider1"
                        app:tint="@color/brand_primary" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvPhoneLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/cuenta_telefono_label"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="@color/brand_primary_light"
                        app:layout_constraintStart_toEndOf="@+id/ivPhone"
                        app:layout_constraintTop_toTopOf="@+id/ivPhone" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvPhoneValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/brand_primary_dark"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/ivPhone"
                        app:layout_constraintTop_toBottomOf="@+id/tvPhoneLabel"
                        tools:text="1234567890" />

                    <View
                        android:id="@+id/divider2"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="@color/brand_primary_light"
                        android:alpha="0.25"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tvPhoneValue" />

                    <!-- Fecha de nacimiento -->
                    <ImageView
                        android:id="@+id/ivBirthDate"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_marginTop="16dp"
                        android:contentDescription="@string/cuenta_nacimiento_label"
                        android:src="@drawable/ic_cake"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/divider2"
                        app:tint="@color/brand_primary" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvBirthDateLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/cuenta_nacimiento_label"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="@color/brand_primary_light"
                        app:layout_constraintStart_toEndOf="@+id/ivBirthDate"
                        app:layout_constraintTop_toTopOf="@+id/ivBirthDate" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvBirthDateValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/brand_primary_dark"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/ivBirthDate"
                        app:layout_constraintTop_toBottomOf="@+id/tvBirthDateLabel"
                        tools:text="2003-11-12" />

                    <View
                        android:id="@+id/divider3"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="@color/brand_primary_light"
                        android:alpha="0.25"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tvBirthDateValue" />

                    <!-- Correo -->
                    <ImageView
                        android:id="@+id/ivEmail"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_marginTop="16dp"
                        android:contentDescription="@string/cuenta_correo_label"
                        android:src="@drawable/ic_email"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/divider3"
                        app:tint="@color/brand_primary" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvEmailLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/cuenta_correo_label"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="@color/brand_primary_light"
                        app:layout_constraintStart_toEndOf="@+id/ivEmail"
                        app:layout_constraintTop_toTopOf="@+id/ivEmail" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvEmail"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/brand_primary_dark"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/ivEmail"
                        app:layout_constraintTop_toBottomOf="@+id/tvEmailLabel"
                        tools:text="samuel@correo.com" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCerrarSesion"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/brand_primary"
                android:text="@string/accion_cerrar_sesion"
                android:textColor="@color/brand_on_primary"
                app:cornerRadius="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/infoContainer" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
