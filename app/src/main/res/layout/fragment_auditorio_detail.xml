<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral_white"
    tools:context=".home.auditorioDetail.AuditorioDetailFragment">

    <ImageView
        android:id="@+id/ivAuditorio"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="@string/cd_auditorio_image"
        android:scaleType="centerCrop"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.30"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:background="@color/brand_primary_light" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_circle_primary"
        android:contentDescription="@string/cd_back"
        android:src="@drawable/ic_arrow_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/brand_on_primary" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="-24dp"
        android:background="@drawable/bg_card_top_rounded"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ivAuditorio">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingTop="28dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvNombre"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="@color/brand_primary_dark"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="Auditorio Principal" />

            <ImageView
                android:id="@+id/ivPeople"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginTop="8dp"
                android:contentDescription="@string/cd_capacidad"
                android:src="@drawable/ic_people"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvNombre"
                app:tint="@color/brand_primary_accent" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvCapacidad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/brand_primary_accent"
                app:layout_constraintBottom_toBottomOf="@+id/ivPeople"
                app:layout_constraintStart_toEndOf="@+id/ivPeople"
                app:layout_constraintTop_toTopOf="@+id/ivPeople"
                tools:text="Capacidad: 500 personas" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvServiciosTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/servicios_adicionales"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/brand_primary_dark"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/ivPeople" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchAudio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/servicio_audio"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvServiciosTitle" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchMaestro"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/servicio_maestro"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/switchAudio" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchMesa"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/servicio_mesa"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/switchMaestro" />

            <ImageView
                android:id="@+id/ivMic"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@string/servicio_microfonos_label"
                android:src="@drawable/ic_mic"
                app:layout_constraintBottom_toBottomOf="@+id/btnMicMas"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/btnMicMas"
                app:tint="@color/brand_primary" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvMicLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/servicio_microfonos_label"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                app:layout_constraintBottom_toBottomOf="@+id/ivMic"
                app:layout_constraintStart_toEndOf="@+id/ivMic"
                app:layout_constraintTop_toTopOf="@+id/ivMic" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMicMas"
                style="@style/Widget.Material3.Button.IconButton.Outlined"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:contentDescription="@string/cd_mic_mas"
                app:icon="@drawable/ic_add"
                app:iconTint="@color/brand_primary"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/switchMesa" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvNumMicrofonos"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/cero"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:textColor="@color/brand_primary_dark"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/btnMicMas"
                app:layout_constraintEnd_toStartOf="@+id/btnMicMas"
                app:layout_constraintTop_toTopOf="@+id/btnMicMas" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMicMenos"
                style="@style/Widget.Material3.Button.IconButton.Outlined"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:contentDescription="@string/cd_mic_menos"
                app:icon="@drawable/ic_remove"
                app:iconTint="@color/brand_primary"
                app:layout_constraintBottom_toBottomOf="@+id/btnMicMas"
                app:layout_constraintEnd_toStartOf="@+id/tvNumMicrofonos"
                app:layout_constraintTop_toTopOf="@+id/btnMicMas" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvFechaHoraTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/fecha_y_hora"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/brand_primary_dark"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btnMicMas" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFecha"
                style="@style/Widget.Material3.Button.OutlinedButton.Icon"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="8dp"
                android:text="@string/selecciona_fecha"
                android:textColor="@color/brand_primary"
                app:icon="@drawable/ic_calendar"
                app:iconTint="@color/brand_primary"
                app:layout_constraintEnd_toStartOf="@+id/btnHora"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvFechaHoraTitle"
                app:strokeColor="@color/brand_primary_accent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHora"
                style="@style/Widget.Material3.Button.OutlinedButton.Icon"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/selecciona_hora"
                android:textColor="@color/brand_primary"
                app:icon="@drawable/ic_clock"
                app:iconTint="@color/brand_primary"
                app:layout_constraintBottom_toBottomOf="@+id/btnFecha"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toEndOf="@+id/btnFecha"
                app:layout_constraintTop_toTopOf="@+id/btnFecha"
                app:strokeColor="@color/brand_primary_accent" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvDisponibilidad"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btnFecha"
                tools:text="✓ Fecha disponible"
                tools:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReservar"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/brand_primary"
                android:enabled="false"
                android:text="@string/accion_reservar"
                android:textColor="@color/brand_on_primary"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvDisponibilidad"
                app:layout_constraintVertical_bias="1.0" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
